{
  "name": "ppt-agent-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "npm run start:all",
    "start:all": "concurrently -k -n FRONTEND,BACKEND \"npm --prefix frontend run dev\" \"python -m uvicorn app.main:app --reload --app-dir backend\"",
    "install:all": "npm install && npm --prefix frontend install",
    "start:frontend": "npm --prefix frontend run dev",
    "start:backend": "python -m uvicorn app.main:app --reload --app-dir backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
